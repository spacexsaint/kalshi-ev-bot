# ════════════════════════════════════════════════════════
# Kalshi EV Bot — Environment Variables
# ════════════════════════════════════════════════════════
# Copy this file to .env and fill in your credentials.
# NEVER commit .env or your private key to version control.

# ── Kalshi API Credentials ──────────────────────────────
# Your API Key ID (UUID format) from kalshi.com/account/profile
# Example: a952bcbe-ec3b-4b5b-b8f9-11dae589608c
KALSHI_API_KEY=

# Path to your RSA private key file (.pem or .key format).
# Generated when you create an API key on Kalshi.
# Store this file securely — Kalshi cannot retrieve it for you.
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# ── Discord Alerting ────────────────────────────────────
# Webhook URL for bet alerts, position closes, and circuit breakers.
# Create a webhook: Discord Server Settings → Integrations → Webhooks
# Leave blank to disable Discord alerts.
DISCORD_WEBHOOK_URL=

# ── Trading Mode ────────────────────────────────────────
# PAPER_MODE=true:  Bot runs in simulation mode. No real orders placed.
#                   Uses the Kalshi demo API (demo-api.kalshi.co).
# PAPER_MODE=false: LIVE TRADING. Real money at risk.
#                   Double-check your risk parameters in bot/config.py
#                   before going live. Run in paper mode for ≥48 hours first.
PAPER_MODE=true
